{
  "$schema": "https://openapi.vercel.sh/microfrontends.json",
  "applications": {
    "psbuniverse_dev": {
      "packageName": "psbuniverse",
      "development": {
        "fallback": "psbuniverse-dev.vercel.app"
      }
    },
    "psb-metal-buildings-app": {
      "development": {
        "fallback": "psb-metal-buildings-app.vercel.app"
      },
      "routing": [
        {
          "group": "psb-metal-buildings-app",
          "paths": [
            "/metal-buildings",
            "/metal-buildings/:path*"
          ]
        }
      ]
    }
  }
}
